# ── Database ──────────────────────────────────────────────────────────────────
# Local dev with local Postgres: leave unset — connects to postgresql://localhost:5432/ysa by default.
# Docker Postgres (full stack or postgres-only): set both.
# POSTGRES_PASSWORD=changeme
# DATABASE_URL=postgresql://app:changeme@localhost:5432/ysa

# ── Security ──────────────────────────────────────────────────────────────────
# Required when running with Docker or in production (server won't start without them).
# Local dev: auto-generated on first run and written to this file.
# Generate: openssl rand -hex 32
# MASTER_KEY=
# AUTH_SECRET=

# ── Instance settings ─────────────────────────────────────────────────────────
# Required for VPS deploys — used to build links in emails and OAuth callbacks.
# ORIGIN=https://your-domain.com

# Set to true to disable public sign-ups (invite-only access).
# SIGNUP_DISABLED=false

# Port the dashboard listens on (default: 3333).
# DASHBOARD_PORT=3333

# ── Email: password reset and email change (optional) ─────────────────────────
# RESEND_API_KEY=
# FROM_EMAIL=

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# VITE_GOOGLE_CLIENT_ID=   # same value as GOOGLE_CLIENT_ID, baked into frontend at build time

# ── Telemetry opt-out ─────────────────────────────────────────────────────────
# YSA_TELEMETRY_DISABLED=1        # server-side telemetry
# VITE_TELEMETRY_DISABLED=1       # client-side telemetry (baked in at build time)
