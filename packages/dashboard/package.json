{
  "name": "@ysa-ai/dashboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "bunx vite",
    "dev:all": "bun --watch server/index.ts & bunx vite; kill %1",
    "build": "bunx vite build",
    "start": "bun server/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "bun test --env-file .env.test --preload ./test-preload.ts server/lib/ server/trpc/ client/ && bun test --env-file .env.test --preload ./test-preload.ts server/ws/"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@tanstack/react-query": "^5.90.20",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@ysa-ai/shared": "workspace:*",
    "@ysa-ai/ysa": "0.4.3",
    "consola": "^3.4.2",
    "drizzle-orm": "^0.44.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.11.9",
    "jose": "^5.9.6",
    "marked": "^17.0.1",
    "postgres": "^3.4.5",
    "posthog-js": "^1.364.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "drizzle-kit": "^0.30.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.8.3",
    "vite": "^7.3.1"
  }
}
